{
  "name": "mythosengine",
  "version": "1.0.0",
  "description": "MythosEngine — D&D Campaign Management",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "npx concurrently \"npx vite\" \"npx wait-on http://localhost:5173 && npx electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:linux": "vite build && electron-builder --linux",
    "build:win": "vite build && electron-builder --win nsis"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.0",
    "@tanstack/react-query": "^5.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.23.0",
    "sonner": "^1.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.11",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.mythosengine.app",
    "productName": "MythosEngine",
    "copyright": "Copyright © 2026 MythosEngine",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist/server",
        "to": "server"
      }
    ],
    "win": {
      "target": [{"target": "nsis", "arch": ["x64"]}],
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MythosEngine",
      "installerIcon": "build-resources/icon.ico",
      "uninstallerIcon": "build-resources/icon.ico",
      "license": "build-resources/license.txt"
    },
    "mac": {
      "target": [{"target": "dmg", "arch": ["arm64", "x64"]}],
      "icon": "build-resources/icon.icns",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "MythosEngine ${version}"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build-resources/icon.png",
      "category": "Office"
    }
  }
}
